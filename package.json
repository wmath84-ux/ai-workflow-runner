{
  "name": "ai-workflow-runner",
  "version": "0.1.0",
  "description": "Foundation for an Electron, React, Playwright, and SQLite AI workflow runner desktop app.",
  "type": "module",
  "main": "app/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "electron:dev": "npm run dev",
    "electron:build": "npm run dist",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "lint": "node app/build/qaCheck.js",
    "test:smoke": "node app/build/qaCheck.js",
    "qa:check": "node app/build/qaCheck.js"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "electron": "latest",
    "playwright": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "wait-on": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "local.ai-workflow-runner",
    "productName": "AI Workflow Runner",
    "files": [
      "app/**",
      "dist/**",
      "workflows/**",
      "README.md",
      "USER_GUIDE.md",
      "TROUBLESHOOTING.md",
      "RELEASE_CHECKLIST.md",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      "workflows"
    ],
    "asar": true,
    "npmRebuild": false,
    "publish": null
  }
}
